;; com-etzhayyim-tsumugu — Spirit in Physics (Ghost Hacker universe) manga
;; publishing actor. StateGraph containment + governor + append-only ledger
;; (CLAUDE.md "Actors"), self-sovereign kotoba-server identity (no owner
;; hand-off), co-scientist quality loop before any panel/page commits.
{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        io.github.com-junkawasaki/langgraph-clj {:local/root "../../com-junkawasaki/langgraph-clj"}
        ;; kami-mangaka-{render,page}-clj were split out of kami-engine and
        ;; renamed to drop the -clj suffix (ADR-2607022800 Phase 2); this repo's
        ;; deps.edn had not been updated to follow, so it still pointed at the
        ;; now-orphaned kami-engine subtree copies. Same fix already applied to
        ;; kami-app-sip's deps.edn (ADR-2607022800 :post-rename-dep-fixes).
        gftd/kami-mangaka-render {:git/url "https://github.com/kotoba-lang/kami-mangaka-render.git"
                                  :sha "2122c2a66c617d05bab21ed423b47b1956f826d3"}
        gftd/kami-mangaka-page   {:git/url "https://github.com/kotoba-lang/kami-mangaka-page.git"
                                  :sha "c416dd96dfefc251d0c66eb87999fb258f7ad315"}}

 :aliases
 {;; override langgraph-clj's transitive langchain-clj — langgraph-clj itself
  ;; still pins the old v0.1.0/ae475c9 tag, which predates the kotoba-conn*
  ;; read/write-scope split (kotoba-lang/langchain#5, merged 8b25753). Drop
  ;; this override once langgraph-clj's own pin advances past that commit.
  :dev {:override-deps {io.github.com-junkawasaki/langchain-clj
                         {:git/url "https://github.com/kotoba-lang/langchain.git"
                          :git/sha "8b25753f12643be51e3697400ed1541d97990304"}}}

  :run  {:main-opts ["-m" "tsumugu.sim"]}

  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                        {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}

  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
